model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meals Meal[]

  @@map("category")
}

model Coupon {
  id                String             @id @default(uuid())
  code              String             @unique
  description       String?
  discountType      CouponDiscountType
  discountValue     Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int                @default(0)
  perUserLimit      Int                @default(1)
  isActive          Boolean            @default(true)
  startsAt          DateTime?
  expiresAt         DateTime?
  providerId        String?
  provider          ProviderProfile?   @relation(fields: [providerId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  orders      Order[]
  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([providerId])
  @@map("coupon")
}

model CouponRedemption {
  id             String   @id @default(uuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId     String
  customer       User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  discountAmount Float
  createdAt      DateTime @default(now())

  @@index([couponId])
  @@index([customerId])
  @@map("coupon_redemption")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
  PROVIDER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COD_PENDING
  PAID
  COD_COLLECTED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  COD
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

model MealFavorite {
  id         String   @id @default(uuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mealId     String
  meal       Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, mealId])
  @@index([customerId])
  @@index([mealId])
  @@map("meal_favorite")
}

model ProviderFavorite {
  id         String          @id @default(uuid())
  customerId String
  customer   User            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([customerId, providerId])
  @@index([customerId])
  @@index([providerId])
  @@map("provider_favorite")
}

model Meal {
  id          String          @id @default(uuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id])
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  title       String
  description String
  price       Float
  image       String?
  isAvailable Boolean         @default(true)
  dietaryTag  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orderItems    OrderItem[]
  reviews       Review[]
  mealFavorites MealFavorite[]

  @@map("meal")
}

model Order {
  id                    String          @id @default(uuid())
  customerId            String
  customer              User            @relation(fields: [customerId], references: [id])
  providerId            String
  provider              ProviderProfile @relation(fields: [providerId], references: [id])
  couponId              String?
  coupon                Coupon?         @relation(fields: [couponId], references: [id])
  subtotalPrice         Float           @default(0)
  discountAmount        Float           @default(0)
  totalPrice            Float
  deliveryAddress       String
  orderStatus           OrderStatus     @default(PLACED)
  paymentStatus         PaymentStatus   @default(PENDING)
  paymentMethod         PaymentMethod   @default(STRIPE)
  stripePaymentIntentId String?         @unique
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  orderItems       OrderItem[]
  couponRedemption CouponRedemption?

  @@map("order")
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mealId     String
  meal       Meal   @relation(fields: [mealId], references: [id])
  quantity   Int
  unitPrice  Float
  totalPrice Float

  @@map("order_item")
}

model ProviderProfile {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id])
  restaurantName         String
  description            String?
  address                String
  cuisineType            String?
  preparationTimeMinutes Int      @default(30)
  timezone               String   @default("UTC")
  logo                   String?
  bannerImage            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  meals               Meal[]
  orders              Order[]
  providerFavorites   ProviderFavorite[]
  availabilityWindows ProviderAvailabilityWindow[]
  specialClosures     ProviderSpecialClosure[]
  coupons             Coupon[]

  @@map("provider_profile")
}

model ProviderAvailabilityWindow {
  id         String          @id @default(uuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([providerId, dayOfWeek])
  @@index([providerId])
  @@map("provider_availability_window")
}

model ProviderSpecialClosure {
  id         String          @id @default(uuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  date       DateTime
  reason     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([providerId, date])
  @@map("provider_special_closure")
}

model Review {
  id         String   @id @default(uuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  mealId     String
  meal       Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([customerId, mealId])
  @@map("review")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  name               String
  emailVerified      Boolean    @default(false)
  image              String?
  role               Role       @default(CUSTOMER)
  status             UserStatus @default(ACTIVE)
  isDeleted          Boolean    @default(false)
  deletedAt          DateTime?
  needPasswordChange Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  sessions Session[]
  accounts Account[]

  providerProfile   ProviderProfile?
  orders            Order[]
  reviews           Review[]
  mealFavorites     MealFavorite[]
  providerFavorites ProviderFavorite[]
  addresses         CustomerAddress[]
  couponRedemptions CouponRedemption[]

  @@map("user")
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerId   String
  customer     User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label        String
  line1        String
  line2        String?
  city         String
  state        String?
  postalCode   String?
  country      String   @default("Bangladesh")
  instructions String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, isDefault])
  @@map("customer_address")
}
