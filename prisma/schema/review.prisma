model Review {
  id         String   @id @default(uuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  mealId     String
  meal       Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  
  @@map("review")
}