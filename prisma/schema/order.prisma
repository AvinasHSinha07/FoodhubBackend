model Order {
  id                    String          @id @default(uuid())
  customerId            String
  customer              User            @relation(fields: [customerId], references: [id])
  providerId            String
  provider              ProviderProfile @relation(fields: [providerId], references: [id])
  couponId              String?
  coupon                Coupon?         @relation(fields: [couponId], references: [id])
  subtotalPrice         Float           @default(0)
  discountAmount        Float           @default(0)
  totalPrice            Float
  platformFeeRate       Float           @default(0.15)
  platformFeeAmount     Float           @default(0)
  serviceFeeAmount      Float           @default(0)
  paymentGatewayFeeAmount Float         @default(0)
  adminCouponSubsidyAmount Float        @default(0)
  providerCouponShareAmount Float       @default(0)
  refundCostToAdmin     Float           @default(0)
  refundCostToProvider  Float           @default(0)
  adminGrossRevenue     Float           @default(0)
  adminNetRevenue       Float           @default(0)
  providerGrossEarning  Float           @default(0)
  providerNetPayout     Float           @default(0)
  customerPaidAmount    Float           @default(0)
  deliveryAddress       String
  orderStatus           OrderStatus     @default(PLACED)
  paymentStatus         PaymentStatus   @default(PENDING)
  paymentMethod         PaymentMethod   @default(STRIPE)
  stripePaymentIntentId String?         @unique
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  orderItems            OrderItem[]
  couponRedemption      CouponRedemption?
  
  @@map("order")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  mealId     String
  meal       Meal     @relation(fields: [mealId], references: [id])
  quantity   Int
  unitPrice  Float
  totalPrice Float
  
  @@map("order_item")
}